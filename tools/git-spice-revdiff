#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

# Calls 'revdiff base head` on the given git-spice tracked branch.

red='\033[0;31m'
reset='\033[0m'

die() {
	echo -e "${red}FTL${reset} $*" >&2
	exit 1
}

revdiff_args=()
want_branch=""
for arg in "$@"; do
	if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
		echo "Usage: git-spice revdiff [branch]"
		exit 0
	elif [[ "$arg" == -* ]]; then
		revdiff_args+=("$arg")
		continue
	fi

	want_branch="$arg"
	break
done

if [[ -z "$want_branch" ]]; then
	want_branch=$(git-spice bco -n)  # prompt for branch name
fi

# Convenience: "@" = current branch
if [[ "$want_branch" == "@" ]]; then
	want_branch=""
fi

while read -r branch_entry; do
	name=$(jq -r '.name' <<< "$branch_entry")
	if [[ -n "$want_branch" ]]; then
		if [[ "$name" != "$want_branch" ]]; then
			continue
		fi
	else
		is_current=$(jq -r '.current' <<< "$branch_entry")
		if [[ "$is_current" != "true" ]]; then
			continue
		fi
	fi

	base=$(jq -r '(.down // {}).name // ""' <<< "$branch_entry")
	if [[ -z "$base" ]]; then
		die "branch '$name' has no base branch"
	fi

	revdiff_args+=("$base...$name")

	# If $name needs to be restacked,
	# then the log in revdiff will be wrong.
	# Capture a (probably) better one.
	needs_restack=$(jq -r '.down.needsRestack // false' <<< "$branch_entry")
	if [[ "$needs_restack" == "true" ]]; then
		log=$(mktemp)
		git log "$base..$name" "^$base" | head -n500 > "$log"
		revdiff_args+=("--description-file=$log")
		trap 'rm -f "$log"' EXIT
	fi

	exec revdiff "${revdiff_args[@]}"
done < <(git-spice ls -a --json)

if [[ -n "$want_branch" ]]; then
	die "branch '$want_branch' not found"
fi
